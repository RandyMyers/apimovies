# Server environment (copy to .env and fill)
NODE_ENV=development
PORT=5000
MONGO_URL=mongodb://localhost:27017/cinehub-social
JWT_SECRET=your-secret-at-least-32-chars-long
JWT_EXPIRES_IN=7d

# Production: comma-separated allowed origins (e.g. client + admin URLs)
# CORS_ORIGIN=http://localhost:3000,http://localhost:3001
# CORS_ORIGIN=https://yourapp.com,https://admin.yourapp.com

# Optional: rate limit for login (default 10 per window)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_LOGIN=10

# Optional: logging level (error, warn, info, debug)
# LOG_LEVEL=info

# TMDb API (optional - for Content page titles/posters)
# TMDB_API_KEY=your-tmdb-api-key

# Cloudinary (if using image upload)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# TMDb API (for Content Analytics titles/posters)
# Get key at https://www.themoviedb.org/settings/api
# TMDB_API_KEY=
